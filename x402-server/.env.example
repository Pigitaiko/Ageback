# === Network Selection ===
# Options: taiko-hoodi | base | base-sepolia
CHAIN=taiko-hoodi

# === x402 Server Configuration ===

# Your wallet address that receives USDC payments from agents
PAY_TO_ADDRESS=0xYourWalletAddress

# x402 facilitator (auto-selected from CHAIN, override if needed)
# taiko-hoodi: https://facilitator.taiko.xyz
# base / base-sepolia: https://x402.org/facilitator
# FACILITATOR_URL=

# Chain RPC (auto-selected from CHAIN, override for private/paid RPC)
# CHAIN_RPC=

# Server port
PORT=4020

# === Cashback Protocol ===

# Private key of the provider wallet (registered on RebatePoolManager)
PROVIDER_PRIVATE_KEY=0xYourPrivateKey

# Deployed contract addresses (written here after running scripts/deploy.js)
REBATE_POOL_MANAGER=
LOYALTY_TIER_MANAGER=
REFERRAL_GRAPH=
REBATE_ACCUMULATOR=

# Block number when RebatePoolManager was deployed (for faster event scanning)
REBATE_POOL_DEPLOYED_BLOCK=0

# === Upstream API ===
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === Demo Agent (for test-agent.js) ===
# AGENT_PRIVATE_KEY=0xYourAgentKey
# SERVER_URL=http://localhost:4020

# ─────────────────────────────────────────────
# Taiko Hoodi testnet example (current default)
# ─────────────────────────────────────────────
# CHAIN=taiko-hoodi
# PAY_TO_ADDRESS=0x...
# PROVIDER_PRIVATE_KEY=0x...
# REBATE_POOL_MANAGER=0x1571922009FC4a9ed68646b9722A9df6FB1fD11d
# LOYALTY_TIER_MANAGER=0x126B3Ec653BD2ca9fe537b5A701bD94eDDFF1F6c
# REFERRAL_GRAPH=0xa9BCFa08f1A2A82339ecA528b58366923dC0B250
# MockUSDC (testnet only): 0xB0b25E80D3a97526b50a73Cb7cEdBCFd4016882F

# ─────────────────────────────────────────────
# Base mainnet example
# ─────────────────────────────────────────────
# CHAIN=base
# PAY_TO_ADDRESS=0x...
# PROVIDER_PRIVATE_KEY=0x...
# REBATE_POOL_MANAGER=   <-- address after running: npx hardhat run scripts/deploy.js --network base
# LOYALTY_TIER_MANAGER=
# REFERRAL_GRAPH=
# USDC on Base: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913 (used automatically)

# === Usage API ===

# Where per-day rollups are persisted. Recommended: a Render Disk path
# like /var/data/usage.json. If unset, runs in-memory only (lost on restart).
# USAGE_DB_PATH=./data/usage.json

# Where API key hashes are persisted. Same disk as USAGE_DB_PATH ideally.
# USAGE_KEYS_PATH=./data/keys.json

# Comma-separated raw API keys to seed at boot (useful when persistent disk
# is unavailable). Keys MUST start with "ageback_". Loaded in addition to
# anything in USAGE_KEYS_PATH.
# AGEBACK_USAGE_API_KEYS=ageback_xxx,ageback_yyy
