# === x402 Server Configuration ===

# Your wallet address that receives USDC payments from agents
PAY_TO_ADDRESS=0xYourWalletAddress

# Taiko x402 facilitator (supports Taiko Hoodi eip155:167013)
FACILITATOR_URL=https://facilitator.taiko.xyz

# === Cashback Protocol (Taiko Hoodi) ===

# Private key of the provider wallet (registered on RebatePoolManager)
PROVIDER_PRIVATE_KEY=0xYourPrivateKey

# Taiko Hoodi RPC
TAIKO_RPC=https://rpc.hoodi.taiko.xyz

# Deployed contract addresses
REBATE_POOL_MANAGER=0x1571922009FC4a9ed68646b9722A9df6FB1fD11d
LOYALTY_TIER_MANAGER=0x126B3Ec653BD2ca9fe537b5A701bD94eDDFF1F6c
REFERRAL_GRAPH=0xa9BCFa08f1A2A82339ecA528b58366923dC0B250

# MockUSDC on Taiko Hoodi (testnet only)
MOCK_USDC=0xB0b25E80D3a97526b50a73Cb7cEdBCFd4016882F

# === Upstream API (what you're reselling) ===

# For Claude reselling:
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Server port
PORT=4020
