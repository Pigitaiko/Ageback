    "x402",
    "ageback",
    "cashback",
    "agentic-payments",
    "taiko",
    "express",
    "middleware"
  ],
  "homepage": "https://github.com/Pigitaiko/ageback#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pigitaiko/Ageback.git",
    "directory": "packages/middleware"
  },
  "bugs": {
    "url": "https://github.com/Pigitaiko/Ageback/issues"
  },
